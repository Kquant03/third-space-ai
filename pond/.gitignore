cat > .gitignore <<'EOF'
# deps
node_modules/
**/node_modules/

# next.js
.next/
out/
build/
dist/

# wrangler
.wrangler/
.dev.vars

# env
.env
.env.local
.env.*.local

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# os / editor
.DS_Store
.vscode/
.idea/
*.swp

# typescript
*.tsbuildinfo
next-env.d.ts
EOF