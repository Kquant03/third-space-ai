{
  "name": "@limen/pond",
  "version": "0.1.0",
  "private": true,
  "description": "Limen Pond — the Durable Object backend for the primary instance of Cúramóir. Runs the koi colony on a 2 Hz alarm-driven tick. Streams to clients via the WebSocket hibernation API. Sees itself as the research instrument of Cúramóir and behaves accordingly.",
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:local": "wrangler d1 migrations apply pond --local",
    "migrate:remote": "wrangler d1 migrations apply pond --remote"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.30",
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.6.3",
    "vitest": "~2.1.0",
    "wrangler": "^3.99.0"
  }
}
